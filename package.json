{
  "name": "coffee-shop-backend-typescript",
  "version": "1.0.0",
  "main": "dist/api/index.js",
  "engine": {
    "node": "20.x"
  },
  "scripts": {
    "clean": "rimraf /dist",
    "build": "npm run clean && tsc && tsc-alias",
    "start": "node dist/api/index.js",
    "dev:local": "cross-env NODE_ENV=local ts-node-dev --respawn --transpile-only -r tsconfig-paths/register api/index.ts",
    "dev:prod": "cross-env NODE_ENV=production ts-node-dev --respawn --transpile-only -r tsconfig-paths/register api/index.ts",
    "knex": "knex --knexfile src/config/knexfile.ts",
    "migrate": "npm run knex migrate:latest",
    "seed": "npm run knex seed:run"
  },
  "_moduleAliases": {
    "@modules": "src/modules",
    "@shared": "src/shared"
  },
  "keywords": [],
  "author": "Moch Fauzi Dwi R",
  "license": "ISC",
  "description": "Beginner Backend FWG 20",
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.2.0",
    "datauri": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.8",
    "make": "^0.0.0",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "pino": "^10.3.1",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/pg": "^8.11.6",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "eslint": "^8.57.0",
    "globals": "^15.2.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^7.8.0"
  }
}
